  | SPECIFICATION_FOR <json name="SPECIFICATION_FOR">
  | FILE_MODIFIED <json name="FILE_MODIFIED">
  | DISTRIBUTION_ARTIFACT <json name="DISTRIBUTION_ARTIFACT">
  | AMENDS <json name="AMENDS">
