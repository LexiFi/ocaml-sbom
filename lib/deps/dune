; Extract info from Opam, in particular:
; - parse lockfiles
; - query the public package repository
(library
  (name sbom_deps)
  (libraries
    opam-format
    fpath
    sbom_types
    sbom_util
    str
  )
)

(rule
  (targets opam_tree.ml opam_tree.mli)
  (deps opam_tree.atd)
  (action (run atdml %{deps}))
)
