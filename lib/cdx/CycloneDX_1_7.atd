type cryptoPropertiesProtocolPropertiesIkev2TransformTypes <doc text="The IKEv2 transform types supported (types 1-4), defined in [RFC 7296 section 3.3.2](https://www.ietf.org/rfc/rfc7296.html#section-3.3.2), and additional properties."> = {
  ?encr <doc text="Transform Type 1: encryption algorithms">: cryptoPropertiesProtocolPropertiesIkev2TransformTypesEncr option;
  ?prf <doc text="Transform Type 2: pseudorandom functions">: cryptoPropertiesProtocolPropertiesIkev2TransformTypesPrf option;
  ?integ <doc text="Transform Type 3: integrity algorithms">: cryptoPropertiesProtocolPropertiesIkev2TransformTypesInteg option;
  ?ke <doc text="Transform Type 4: Key Exchange Method (KE) per [RFC 9370](https://www.ietf.org/rfc/rfc9370.html), formerly called Diffie-Hellman Group (D-H).">: cryptoPropertiesProtocolPropertiesIkev2TransformTypesKe option;
  ?esn <doc text="Specifies if an Extended Sequence Number (ESN) is used.">: bool option;
  ?auth <doc text="IKEv2 Authentication method per [RFC9593](https://www.ietf.org/rfc/rfc9593.html).">: cryptoPropertiesProtocolPropertiesIkev2TransformTypesAuth option;
}

type cryptoPropertiesProtocolProperties <doc text="Properties specific to cryptographic assets of type: `protocol`."> = {
  ?type_ <json name="type"> <doc text="The concrete protocol type.">: cryptoPropertiesProtocolPropertiesType option;
  ?version <doc text="The version of the protocol.">: string option;
  ?cipherSuites <doc text="A list of cipher suites related to the protocol.">: cipherSuite list option;
  ?ikev2TransformTypes <doc text="The IKEv2 transform types supported (types 1-4), defined in [RFC 7296 section 3.3.2](https://www.ietf.org/rfc/rfc7296.html#section-3.3.2), and additional properties.">: cryptoPropertiesProtocolPropertiesIkev2TransformTypes option;
  ?cryptoRefArray : cryptoRefArray option;
  ?relatedCryptographicAssets : relatedCryptographicAssets option;
}

type patentPatentLegalStatus <doc text="Indicates the current legal status of the patent or patent application, based on the WIPO ST.27 standard. This status reflects administrative, procedural, or legal events. Values include both active and inactive states and are useful for determining enforceability, procedural history, and maintenance status."> = [
  | Pending <json name="pending">
  | Granted <json name="granted">
  | Revoked <json name="revoked">
  | Expired <json name="expired">
  | Lapsed <json name="lapsed">
  | Withdrawn <json name="withdrawn">
  | Abandoned <json name="abandoned">
  | Suspended <json name="suspended">
  | Reinstated <json name="reinstated">
  | Opposed <json name="opposed">
  | Terminated <json name="terminated">
  | Invalidated <json name="invalidated">
  | Inforce <json name="in-force">
] <ocaml repr="classic">

type patentPatentAssignee = [
  | OrganizationalContact of organizationalContact
  | OrganizationalEntity of organizationalEntity
] <json adapter.ocaml="Jsonschema2atd_runtime.Adapter.One_of"> <ocaml repr="classic">

type patentAssertionsItemsAssertionType <doc text="The type of assertion being made about the patent or patent family. Examples include ownership, licensing, and standards inclusion."> = [
  | Ownership <json name="ownership">
  | License <json name="license">
  | Thirdpartyclaim <json name="third-party-claim">
  | Standardsinclusion <json name="standards-inclusion">
  | Priorart <json name="prior-art">
  | Exclusiverights <json name="exclusive-rights">
  | Nonassertion <json name="non-assertion">
  | Researchorevaluation <json name="research-or-evaluation">
] <ocaml repr="classic">

type patentAssertionsItemsAsserter = [
  | OrganizationalEntity of organizationalEntity
  | OrganizationalContact of organizationalContact
  | RefLinkType of refLinkType
] <json adapter.ocaml="Jsonschema2atd_runtime.Adapter.One_of"> <ocaml repr="classic">

type patentAssertionsItems <doc text="An assertion linking a patent or patent family to this component or service."> = {
  ?bomref <json name="bom-ref"> : refType option;
  assertionType <doc text="The type of assertion being made about the patent or patent family. Examples include ownership, licensing, and standards inclusion.">: patentAssertionsItemsAssertionType;
  ?patentRefs <doc text="A list of BOM references (`bom-ref`) linking to patents or patent families associated with this assertion.">: refType list option;
  asserter : patentAssertionsItemsAsserter;
  ?notes <doc text="Additional notes or clarifications regarding the assertion, if necessary. For example, geographical restrictions, duration, or limitations of a license.">: string option;
}

type citation <doc text="Details a specific attribution of data within the BOM to a contributing entity or process."> = [
  | Jsoncitation_1 of json (* citation/Jsoncitation_1 *)
  | Jsoncitation_2 of json (* citation/Jsoncitation_2 *)
] <json adapter.ocaml="Jsonschema2atd_runtime.Adapter.One_of"> <ocaml repr="classic">

type priorityApplication <doc text="The priorityApplication contains the essential data necessary to identify and reference an earlier patent filing for priority rights. In line with WIPO ST.96 guidelines, it includes the jurisdiction (office code), application number, and filing date-the three key elements that uniquely specify the priority application in a global patent context."> = {
  applicationNumber : patentApplicationNumber;
  jurisdiction : patentJurisdiction;
  filingDate : patentFilingDate;
}

type patentFilingDate <doc text="The date the priority application was filed, aligned with `FilingDate` in ST.96. Refer to [FilingDate in ST.96](https://www.wipo.int/standards/XMLSchema/ST96/V8_0/Patent/FilingDate.xsd)."> = string

type patentJurisdiction <doc text="The jurisdiction or patent office where the priority application was filed, specified using WIPO ST.3 codes. Aligned with `IPOfficeCode` in ST.96. Refer to [IPOfficeCode in ST.96](https://www.wipo.int/standards/XMLSchema/ST96/V8_0/Common/IPOfficeCode.xsd)."> = string

type patentApplicationNumber <doc text="The unique number assigned to a patent application when it is filed with a patent office. It is used to identify the specific application and track its progress through the examination process. Aligned with `ApplicationNumber` in ST.96. Refer to [ApplicationIdentificationType in ST.96](https://www.wipo.int/standards/XMLSchema/ST96/V8_0/Patent/ApplicationIdentificationType.xsd)."> = string

type patentAssertions <doc text="A list of assertions made regarding patents associated with this component or service. Assertions distinguish between ownership, licensing, and other relevant interactions with patents."> = patentAssertionsItems list

type patent <doc text="A patent is a legal instrument, granted by an authority, that confers certain rights over an invention for a specified period, contingent on public disclosure and adherence to relevant legal requirements. The summary information in this object is aligned with [WIPO ST.96](https://www.wipo.int/standards/en/st96/) principles where applicable."> = {
  ?bomref <json name="bom-ref"> : refType option;
  patentNumber <doc text="The unique number assigned to the granted patent by the issuing authority. Aligned with `PatentNumber` in WIPO ST.96. Refer to [PatentNumber in ST.96](https://www.wipo.int/standards/XMLSchema/ST96/V8_0/Patent/PatentNumber.xsd).">: string;
  ?applicationNumber : patentApplicationNumber option;
  jurisdiction : patentJurisdiction;
  ?priorityApplication : priorityApplication option;
  ?publicationNumber <doc text="This is the number assigned to a patent application once it is published. Patent applications are generally published 18 months after filing (unless an applicant requests non-publication). This number is distinct from the application number. \n\nPurpose: Identifies the publicly available version of the application. \n\nFormat: Varies by jurisdiction, often similar to application numbers but includes an additional suffix indicating publication. \n\nExample:\n - US: US20240000123A1 (indicates the first publication of application US20240000123) \n - Europe: EP23123456A1 (first publication of European application EP23123456). \n\nWIPO ST.96 v8.0: \n - Publication Number field: https://www.wipo.int/standards/XMLSchema/ST96/V8_0/Patent/PublicationNumber.xsd">: string option;
  ?title <doc text="The title of the patent, summarising the invention it protects. Aligned with `InventionTitle` in WIPO ST.96. Refer to [InventionTitle in ST.96](https://www.wipo.int/standards/XMLSchema/ST96/V8_0/Patent/InventionTitle.xsd).">: string option;
  ?abstract <doc text="A brief summary of the invention described in the patent. Aligned with `Abstract` and `P` in WIPO ST.96. Refer to [Abstract in ST.96](https://www.wipo.int/standards/XMLSchema/ST96/V8_0/Patent/Abstract.xsd).">: string option;
  ?filingDate <doc text="The date the patent application was filed with the jurisdiction. Aligned with `FilingDate` in WIPO ST.96. Refer to [FilingDate in ST.96](https://www.wipo.int/standards/XMLSchema/ST96/V8_0/Patent/FilingDate.xsd).">: string option;
  ?grantDate <doc text="The date the patent was granted by the jurisdiction. Aligned with `GrantDate` in WIPO ST.96. Refer to [GrantDate in ST.96](https://www.wipo.int/standards/XMLSchema/ST96/V8_0/Patent/GrantDate.xsd).">: string option;
  ?patentExpirationDate <doc text="The date the patent expires. Derived from grant or filing date according to jurisdiction-specific rules.">: string option;
  patentLegalStatus <doc text="Indicates the current legal status of the patent or patent application, based on the WIPO ST.27 standard. This status reflects administrative, procedural, or legal events. Values include both active and inactive states and are useful for determining enforceability, procedural history, and maintenance status.">: patentPatentLegalStatus;
  ?patentAssignee <doc text="A collection of organisations or individuals to whom the patent rights are assigned. This supports joint ownership and allows for flexible representation of both corporate entities and individual inventors.">: patentPatentAssignee list option;
  ?externalReferences <doc text="External references provide a way to document systems, sites, and information that may be relevant but are not included with the BOM. They may also establish specific relationships within or external to the BOM.">: externalReference list option;
}

type patentFamily <doc text="A patent family is a group of related patent applications or granted patents that cover the same or similar invention. These patents are filed in multiple jurisdictions to protect the invention across different regions or countries. A patent family typically includes patents that share a common priority date, originating from the same initial application, and may vary slightly in scope or claims to comply with regional legal frameworks. Fields align with WIPO ST.96 standards where applicable."> = {
  ?bomref <json name="bom-ref"> : refType option;
  familyId <doc text="The unique identifier for the patent family, aligned with the `id` attribute in WIPO ST.96 v8.0's `PatentFamilyType`. Refer to [PatentFamilyType in ST.96](https://www.wipo.int/standards/XMLSchema/ST96/V8_0/Patent/PatentFamilyType.xsd).">: string;
  ?priorityApplication : priorityApplication option;
  ?members <doc text="A collection of patents or applications that belong to this family, each identified by a `bom-ref` pointing to a patent object defined elsewhere in the BOM.">: refLinkType list option;
  ?externalReferences <doc text="External references provide a way to document systems, sites, and information that may be relevant but are not included with the BOM. They may also establish specific relationships within or external to the BOM.">: externalReference list option;
}

type tags <doc text="Textual strings that aid in discovery, search, and retrieval of the associated object. Tags often serve as a way to group or categorize similar or related objects by various attributes."> = string list

type securedBy <doc text="Specifies the mechanism by which the cryptographic asset is secured by"> = {
  ?mechanism <doc text="Specifies the mechanism by which the cryptographic asset is secured by.">: string option;
  ?algorithmRef : refType option;
}

type relatedCryptographicAsset <doc text="A cryptographic assets related to this component."> = {
  ?type_ <json name="type"> <doc text="Specifies the mechanism by which the cryptographic asset is secured by.">: string option;
  ?ref : refType option;
}

type relatedCryptographicAssets <doc text="A list of cryptographic assets related to this component."> = relatedCryptographicAsset list

type cryptoRefArray <doc text="Deprecated definition."> = refType list

type ikeV2Auth <doc text="Object representing a IKEv2 Authentication method"> = {
  ?name <doc text="A name for the authentication method.">: string option;
  ?algorithm : refType option;
}

type ikeV2Ke <doc text="Object representing a key exchange method (KE)"> = {
  ?group <doc text="A group identifier for the key exchange algorithm.">: int option;
  ?algorithm : refType option;
}

type ikeV2Integ <doc text="Object representing an integrity algorithm (INTEG)"> = {
  ?name <doc text="A name for the integrity algorithm.">: string option;
  ?algorithm : refType option;
}

type ikeV2Prf <doc text="Object representing a pseudorandom function (PRF)"> = {
  ?name <doc text="A name for the pseudorandom function.">: string option;
  ?algorithm : refType option;
}

type ikeV2Enc <doc text="Object representing an encryption algorithm (ENCR)"> = {
  ?name <doc text="A name for the encryption method.">: string option;
  ?keyLength <doc text="The key length of the encryption algorithm.">: int option;
  ?algorithm : refType option;
}

type cipherSuite <doc text="Object representing a cipher suite"> = {
  ?name <doc text="A common name for the cipher suite.">: string option;
  ?algorithms <doc text="A list of algorithms related to the cipher suite.">: refType list option;
  ?identifiers <doc text="A list of common identifiers for the cipher suite.">: string list option;
  ?tlsGroups <doc text="A list of TLS named groups (formerly known as curves) for this cipher suite. These groups define the parameters for key exchange algorithms like ECDHE.">: string list option;
  ?tlsSignatureSchemes <doc text="A list of signature schemes supported for cipher suite. These schemes specify the algorithms used for digital signatures in TLS handshakes and certificate verification.">: string list option;
}

type cryptoProperties <doc text="Cryptographic assets have properties that uniquely define them and that make them actionable for further reasoning. As an example, it makes a difference if one knows the algorithm family (e.g. AES) or the specific variant or instantiation (e.g. AES-128-GCM). This is because the security level and the algorithm primitive (authenticated encryption) are only defined by the definition of the algorithm variant. The presence of a weak cryptographic algorithm like SHA1 vs. HMAC-SHA1 also makes a difference."> = {
  assetType <doc text="Cryptographic assets occur in several forms. Algorithms and protocols are most commonly implemented in specialized cryptographic libraries. They may, however, also be 'hardcoded' in software components. Certificates and related cryptographic material like keys, tokens, secrets or passwords are other cryptographic assets to be modelled.">: cryptoPropertiesAssetType;
  ?algorithmProperties <doc text="Additional properties specific to a cryptographic algorithm.">: cryptoPropertiesAlgorithmProperties option;
  ?certificateProperties <doc text="Properties for cryptographic assets of asset type 'certificate'">: cryptoPropertiesCertificateProperties option;
  ?relatedCryptoMaterialProperties <doc text="Properties for cryptographic assets of asset type: `related-crypto-material`">: cryptoPropertiesRelatedCryptoMaterialProperties option;
  ?protocolProperties <doc text="Properties specific to cryptographic assets of type: `protocol`.">: cryptoPropertiesProtocolProperties option;
  ?oid <doc text="The object identifier (OID) of the cryptographic asset.">: string option;
}

type signature <doc text="Enveloped signature in [JSON Signature Format (JSF)](https://cyberphone.github.io/doc/security/jsf.html)."> = json (* signature *)

type standard <doc text="A standard may consist of regulations, industry or organizational-specific standards, maturity models, best practices, or any other requirements which can be evaluated against or attested to."> = {
  ?bomref <json name="bom-ref"> : refType option;
  ?name <doc text="The name of the standard. This will often be a shortened, single name of the standard.">: string option;
  ?version <doc text="The version of the standard.">: string option;
  ?description <doc text="The description of the standard.">: string option;
  ?owner <doc text="The owner of the standard, often the entity responsible for its release.">: string option;
  ?requirements <doc text="The list of requirements comprising the standard.">: standardRequirements list option;
  ?levels <doc text="The list of levels associated with the standard. Some standards have different levels of compliance.">: standardLevels list option;
  ?externalReferences <doc text="External references provide a way to document systems, sites, and information that may be relevant but are not included with the BOM. They may also establish specific relationships within or external to the BOM.">: externalReference list option;
  ?signature : signature option;
}

type componentIdentityEvidence <doc text="Evidence that substantiates the identity of a component."> = {
  field <doc text="The identity field of the component which the evidence describes.">: componentIdentityEvidenceField;
  ?confidence <doc text="The overall confidence of the evidence from 0 - 1, where 1 is 100% confidence.">: float option;
  ?concludedValue <doc text="The value of the field (cpe, purl, etc) that has been concluded based on the aggregate of all methods (if available).">: string option;
  ?methods <doc text="The methods used to extract and/or analyze the evidence.">: componentIdentityEvidenceMethods list option;
  ?tools <doc text="The object in the BOM identified by its bom-ref. This is often a component or service but may be any object type supporting bom-refs. Tools used for analysis should already be defined in the BOM, either in the metadata/tools, components, or formulation.">: componentIdentityEvidenceTools list option;
}

type parameter <doc text="A representation of a functional parameter."> = {
  ?name <doc text="The name of the parameter.">: string option;
  ?value <doc text="The value of the parameter.">: string option;
  ?dataType <doc text="The data type of the parameter.">: string option;
}

type taskType = [
  | Copy <json name="copy">
  | Clone <json name="clone">
  | Lint <json name="lint">
  | Scan <json name="scan">
  | Merge <json name="merge">
  | Build <json name="build">
  | Test <json name="test">
  | Deliver <json name="deliver">
  | Deploy <json name="deploy">
  | Release <json name="release">
  | Clean <json name="clean">
  | Other <json name="other">
] <ocaml repr="classic">

type condition <doc text="A condition that was used to determine a trigger should be activated."> = {
  ?description <doc text="Describes the set of conditions which cause the trigger to activate.">: string option;
  ?expression <doc text="The logical expression that was evaluated that determined the trigger should be fired.">: string option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type resourceReferenceChoice <doc text="A reference to a locally defined resource (e.g., a bom-ref) or an externally accessible resource."> = [
  | JsonresourceReferenceChoice_1 of json (* resourceReferenceChoice/JsonresourceReferenceChoice_1 *)
  | JsonresourceReferenceChoice_2 of json (* resourceReferenceChoice/JsonresourceReferenceChoice_2 *)
] <json adapter.ocaml="Jsonschema2atd_runtime.Adapter.One_of"> <ocaml repr="classic">

type outputType = [
  | JsonoutputType_1 of json (* outputType/JsonoutputType_1 *)
  | JsonoutputType_2 of json (* outputType/JsonoutputType_2 *)
  | JsonoutputType_3 of json (* outputType/JsonoutputType_3 *)
] <json adapter.ocaml="Jsonschema2atd_runtime.Adapter.One_of"> <ocaml repr="classic">

type inputType <doc text="Type that represents various input data types and formats."> = [
  | JsoninputType_1 of json (* inputType/JsoninputType_1 *)
  | JsoninputType_2 of json (* inputType/JsoninputType_2 *)
  | JsoninputType_3 of json (* inputType/JsoninputType_3 *)
  | JsoninputType_4 of json (* inputType/JsoninputType_4 *)
] <json adapter.ocaml="Jsonschema2atd_runtime.Adapter.One_of"> <ocaml repr="classic">

type event <doc text="Represents something that happened that may trigger a response."> = {
  ?uid <doc text="The unique identifier of the event.">: string option;
  ?description <doc text="A description of the event.">: string option;
  ?timeReceived <doc text="The date and time (timestamp) when the event was received.">: string option;
  ?data : attachment option;
  ?source : resourceReferenceChoice option;
  ?target : resourceReferenceChoice option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type trigger <doc text="Represents a resource that can conditionally activate (or fire) tasks based upon associated events and their data."> = {
  bomref <json name="bom-ref"> : refType;
  uid <doc text="The unique identifier for the resource instance within its deployment context.">: string;
  ?name <doc text="The name of the resource instance.">: string option;
  ?description <doc text="A description of the resource instance.">: string option;
  ?resourceReferences <doc text="References to component or service resources that are used to realize the resource instance.">: resourceReferenceChoice list option;
  type_ <json name="type"> <doc text="The source type of event which caused the trigger to fire.">: triggerType;
  ?event : event option;
  ?conditions <doc text="A list of conditions used to determine if a trigger should be activated.">: condition list option;
  ?timeActivated <doc text="The date and time (timestamp) when the trigger was activated.">: string option;
  ?inputs <doc text="Represents resources and data brought into a task at runtime by executor or task commands">: inputType list option;
  ?outputs <doc text="Represents resources and data output from a task at runtime by executor or task commands">: outputType list option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type volume <doc text="An identifiable, logical unit of data storage tied to a physical device."> = {
  ?uid <doc text="The unique identifier for the volume instance within its deployment context.">: string option;
  ?name <doc text="The name of the volume instance">: string option;
  ~mode <doc text="The mode for the volume instance."> <ocaml default="Filesystem">: volumeMode;
  ?path <doc text="The underlying path created from the actual volume.">: string option;
  ?sizeAllocated <doc text="The allocated size of the volume accessible to the associated workspace. This should include the scalar size as well as IEC standard unit in either decimal or binary form.">: string option;
  ?persistent <doc text="Indicates if the volume persists beyond the life of the resource it is associated with.">: bool option;
  ?remote <doc text="Indicates if the volume is remotely (i.e., network) attached.">: bool option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type workspace <doc text="A named filesystem or data resource shareable by workflow tasks."> = {
  bomref <json name="bom-ref"> : refType;
  uid <doc text="The unique identifier for the resource instance within its deployment context.">: string;
  ?name <doc text="The name of the resource instance.">: string option;
  ?aliases <doc text="The names for the workspace as referenced by other workflow tasks. Effectively, a name mapping so other tasks can use their own local name in their steps.">: string list option;
  ?description <doc text="A description of the resource instance.">: string option;
  ?resourceReferences <doc text="References to component or service resources that are used to realize the resource instance.">: resourceReferenceChoice list option;
  ?accessMode <doc text="Describes the read-write access control for the workspace relative to the owning resource instance.">: workspaceAccessMode option;
  ?mountPath <doc text="A path to a location on disk where the workspace will be available to the associated task's steps.">: string option;
  ?managedDataType <doc text="The name of a domain-specific data type the workspace represents.">: string option;
  ?volumeRequest <doc text="Identifies the reference to the request for a specific volume type and parameters.">: string option;
  ?volume : volume option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type command = {
  ?executed <doc text="A text representation of the executed command.">: string option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type step <doc text="Executes specific commands or tools in order to accomplish its owning task as part of a sequence."> = {
  ?name <doc text="A name for the step.">: string option;
  ?description <doc text="A description of the step.">: string option;
  ?commands <doc text="Ordered list of commands or directives for the step">: command list option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type task <doc text="Describes the inputs, sequence of steps and resources used to accomplish a task and its output."> = {
  bomref <json name="bom-ref"> : refType;
  uid <doc text="The unique identifier for the resource instance within its deployment context.">: string;
  ?name <doc text="The name of the resource instance.">: string option;
  ?description <doc text="A description of the resource instance.">: string option;
  ?resourceReferences <doc text="References to component or service resources that are used to realize the resource instance.">: resourceReferenceChoice list option;
  taskTypes <doc text="Indicates the types of activities performed by the set of workflow tasks.">: taskType list;
  ?trigger : trigger option;
  ?steps <doc text="The sequence of steps for the task.">: step list option;
  ?inputs <doc text="Represents resources and data brought into a task at runtime by executor or task commands">: inputType list option;
  ?outputs <doc text="Represents resources and data output from a task at runtime by executor or task commands">: outputType list option;
  ?timeStart <doc text="The date and time (timestamp) when the task started.">: string option;
  ?timeEnd <doc text="The date and time (timestamp) when the task ended.">: string option;
  ?workspaces <doc text="A set of named filesystem or data resource shareable by workflow tasks.">: workspace list option;
  ?runtimeTopology <doc text="A graph of the component runtime topology for task's instance.">: dependency list option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type workflow <doc text="A specialized orchestration task."> = {
  bomref <json name="bom-ref"> : refType;
  uid <doc text="The unique identifier for the resource instance within its deployment context.">: string;
  ?name <doc text="The name of the resource instance.">: string option;
  ?description <doc text="A description of the resource instance.">: string option;
  ?resourceReferences <doc text="References to component or service resources that are used to realize the resource instance.">: resourceReferenceChoice list option;
  ?tasks <doc text="The tasks that comprise the workflow.">: task list option;
  ?taskDependencies <doc text="The graph of dependencies between tasks within the workflow.">: dependency list option;
  taskTypes <doc text="Indicates the types of activities performed by the set of workflow tasks.">: taskType list;
  ?trigger : trigger option;
  ?steps <doc text="The sequence of steps for the task.">: step list option;
  ?inputs <doc text="Represents resources and data brought into a task at runtime by executor or task commands">: inputType list option;
  ?outputs <doc text="Represents resources and data output from a task at runtime by executor or task commands">: outputType list option;
  ?timeStart <doc text="The date and time (timestamp) when the task started.">: string option;
  ?timeEnd <doc text="The date and time (timestamp) when the task ended.">: string option;
  ?workspaces <doc text="A set of named filesystem or data resource shareable by workflow tasks.">: workspace list option;
  ?runtimeTopology <doc text="A graph of the component runtime topology for workflow's instance.">: dependency list option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type formula <doc text="Describes workflows and resources that captures rules and other aspects of how the associated BOM component or service was formed."> = {
  ?bomref <json name="bom-ref"> : refType option;
  ?components <doc text="Transient components that are used in tasks that constitute one or more of this formula's workflows">: component list option;
  ?services <doc text="Transient services that are used in tasks that constitute one or more of this formula's workflows">: service list option;
  ?workflows <doc text="List of workflows that can be declared to accomplish specific orchestrated goals and independently triggered.">: workflow list option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type postalAddress <doc text="An address used to identify a contactable location."> = {
  ?bomref <json name="bom-ref"> : refType option;
  ?country <doc text="The country name or the two-letter ISO 3166-1 country code.">: string option;
  ?region <doc text="The region or state in the country.">: string option;
  ?locality <doc text="The locality or city within the country.">: string option;
  ?postOfficeBoxNumber <doc text="The post office box number.">: string option;
  ?postalCode <doc text="The postal code.">: string option;
  ?streetAddress <doc text="The street address.">: string option;
}

type energyProvider <doc text="Describes the physical provider of energy used for model development or operations."> = {
  ?bomref <json name="bom-ref"> : refType option;
  ?description <doc text="A description of the energy provider.">: string option;
  organization : organizationalEntity;
  energySource <doc text="The energy source for the energy provider.">: energyProviderEnergySource;
  energyProvided : energyMeasure;
  ?externalReferences <doc text="External references provide a way to document systems, sites, and information that may be relevant but are not included with the BOM. They may also establish specific relationships within or external to the BOM.">: externalReference list option;
}

type co2Measure <doc text="A measure of carbon dioxide (CO2)."> = {
  value <doc text="Quantity of carbon dioxide (CO2).">: float;
  unit <doc text="Unit of carbon dioxide (CO2).">: co2MeasureUnit;
}

type energyMeasure <doc text="A measure of energy."> = {
  value <doc text="Quantity of energy.">: float;
  unit <doc text="Unit of energy.">: energyMeasureUnit;
}

type energyConsumption <doc text="Describes energy consumption information incurred for the specified lifecycle activity."> = {
  activity <doc text="The type of activity that is part of a machine learning model development or operational lifecycle.">: energyConsumptionActivity;
  energyProviders <doc text="The provider(s) of the energy consumed by the associated model development lifecycle activity.">: energyProvider list;
  activityEnergyCost : energyMeasure;
  ?co2CostEquivalent : co2Measure option;
  ?co2CostOffset : co2Measure option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type environmentalConsiderations <doc text="Describes various environmental impact metrics."> = {
  ?energyConsumptions <doc text="Describes energy consumption information incurred for one or more component lifecycle activities.">: energyConsumption list option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type dataClassification <doc text="Data classification tags data according to its type, sensitivity, and value if altered, stolen, or destroyed."> = string

type fairnessAssessment <doc text="Information about the benefits and harms of the model to an identified at risk group."> = {
  ?groupAtRisk <doc text="The groups or individuals at risk of being systematically disadvantaged by the model.">: string option;
  ?benefits <doc text="Expected benefits to the identified groups.">: string option;
  ?harms <doc text="Expected harms to the identified groups.">: string option;
  ?mitigationStrategy <doc text="With respect to the benefits and harms outlined, please describe any mitigation strategy implemented.">: string option;
}

type risk = {
  ?name <doc text="The name of the risk.">: string option;
  ?mitigationStrategy <doc text="Strategy used to address this risk.">: string option;
}

type performanceMetric = {
  ?type_ <json name="type"> <doc text="The type of performance metric.">: string option;
  ?value <doc text="The value of the performance metric.">: string option;
  ?slice <doc text="The name of the slice this metric was computed on. By default, assume this metric is not sliced.">: string option;
  ?confidenceInterval <doc text="The confidence interval of the metric.">: performanceMetricConfidenceInterval option;
}

type graphic = {
  ?name <doc text="The name of the graphic.">: string option;
  ?image : attachment option;
}

type graphicsCollection <doc text="A collection of graphics that represent various measurements."> = {
  ?description <doc text="A description of this collection of graphics.">: string option;
  ?collection <doc text="A collection of graphics.">: graphic list option;
}

type dataGovernanceResponsibleParty = [
  | JsondataGovernanceResponsibleParty_1 of json (* dataGovernanceResponsibleParty/JsondataGovernanceResponsibleParty_1 *)
  | JsondataGovernanceResponsibleParty_2 of json (* dataGovernanceResponsibleParty/JsondataGovernanceResponsibleParty_2 *)
] <json adapter.ocaml="Jsonschema2atd_runtime.Adapter.One_of"> <ocaml repr="classic">

type dataGovernance <doc text="Data governance captures information regarding data ownership, stewardship, and custodianship, providing insights into the individuals or entities responsible for managing, overseeing, and safeguarding the data throughout its lifecycle."> = {
  ?custodians <doc text="Data custodians are responsible for the safe custody, transport, and storage of data.">: dataGovernanceResponsibleParty list option;
  ?stewards <doc text="Data stewards are responsible for data content, context, and associated business rules.">: dataGovernanceResponsibleParty list option;
  ?owners <doc text="Data owners are concerned with risk and appropriate access to data.">: dataGovernanceResponsibleParty list option;
}

type componentData = {
  ?bomref <json name="bom-ref"> : refType option;
  type_ <json name="type"> <doc text="The general theme or subject matter of the data being specified.">: componentDataType;
  ?name <doc text="The name of the dataset.">: string option;
  ?contents <doc text="The contents or references to the contents of the data being described.">: componentDataContents option;
  ?classification : dataClassification option;
  ?sensitiveData <doc text="A description of any sensitive data in a dataset.">: string list option;
  ?graphics : graphicsCollection option;
  ?description <doc text="A description of the dataset. Can describe size of dataset, whether it's used for source code, training, testing, or validation, etc.">: string option;
  ?governance : dataGovernance option;
}

type inputOutputMLParameters = {
  ?format <doc text="The data format for input/output to the model.">: string option;
}

type modelCard <doc text="A model card describes the intended uses of a machine learning model and potential limitations, including biases and ethical considerations. Model cards typically contain the training parameters, which datasets were used to train the model, performance metrics, and other relevant data useful for ML transparency. This object SHOULD be specified for any component of type `machine-learning-model` and must not be specified for other component types."> = {
  ?bomref <json name="bom-ref"> : refType option;
  ?modelParameters <doc text="Hyper-parameters for construction of the model.">: modelCardModelParameters option;
  ?quantitativeAnalysis <doc text="A quantitative analysis of the model">: modelCardQuantitativeAnalysis option;
  ?considerations <doc text="What considerations should be taken into account regarding the model's construction, training, and application?">: modelCardConsiderations option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type annotations <doc text="A comment, note, explanation, or similar textual content which provides additional context to the object(s) being annotated."> = {
  ?bomref <json name="bom-ref"> : refType option;
  subjects <doc text="The object in the BOM identified by its bom-ref. This is often a component or service, but may be any object type supporting bom-refs.">: annotationsSubjects list;
  annotator <doc text="The organization, person, component, or service which created the textual content of the annotation.">: annotationsAnnotator;
  timestamp <doc text="The date and time (timestamp) when the annotation was created.">: string;
  text <doc text="The textual content of the annotation.">: string;
  ?signature : signature option;
}

type range <doc text="Deprecated definition. use definition `versionRange` instead."> = json (* range *)

type versionRange <doc text="A version range specified in Package URL Version Range syntax (vers) which is defined at https://github.com/package-url/vers-spec"> = string

type version <doc text="A single disjunctive version identifier, for a component or service."> = string

type affectedStatus <doc text="The vulnerability status of a given version or range of versions of a product. The statuses 'affected' and 'unaffected' indicate that the version is affected or unaffected by the vulnerability. The status 'unknown' indicates that it is unknown or unspecified whether the given version is affected. There can be many reasons for an 'unknown' status, including that an investigation has not been undertaken or that a vendor has not disclosed the status."> = [
  | Affected <json name="affected">
  | Unaffected <json name="unaffected">
  | Unknown <json name="unknown">
] <ocaml repr="classic">

type vulnerability <doc text="Defines a weakness in a component or service that could be exploited or triggered by a threat source."> = {
  ?bomref <json name="bom-ref"> : refType option;
  ?id <doc text="The identifier that uniquely identifies the vulnerability.">: string option;
  ?source : vulnerabilitySource option;
  ?references <doc text="Zero or more pointers to vulnerabilities that are the equivalent of the vulnerability specified. Often times, the same vulnerability may exist in multiple sources of vulnerability intelligence, but have different identifiers. References provide a way to correlate vulnerabilities across multiple sources of vulnerability intelligence.">: vulnerabilityReferences list option;
  ?ratings <doc text="List of vulnerability ratings. Consumers SHOULD consider ratings in prioritization decisions; source ratings may differ and aid prioritization.">: rating list option;
  ?cwes <doc text="List of Common Weaknesses Enumerations (CWEs) codes that describes this vulnerability.">: cwe list option;
  ?description <doc text="A description of the vulnerability as provided by the source.">: string option;
  ?detail <doc text="If available, an in-depth description of the vulnerability as provided by the source organization. Details often include information useful in understanding root cause.">: string option;
  ?recommendation <doc text="Recommendations of how the vulnerability can be remediated or mitigated.">: string option;
  ?workaround <doc text="A bypass, usually temporary, of the vulnerability that reduces its likelihood and/or impact. Workarounds often involve changes to configuration or deployments.">: string option;
  ?proofOfConcept <doc text="Evidence used to reproduce the vulnerability.">: vulnerabilityProofOfConcept option;
  ?advisories <doc text="Published advisories of the vulnerability if provided.">: advisory list option;
  ?created <doc text="The date and time (timestamp) when the vulnerability record was created in the vulnerability database.">: string option;
  ?published <doc text="The date and time (timestamp) when the vulnerability record was first published.">: string option;
  ?updated <doc text="The date and time (timestamp) when the vulnerability record was last updated.">: string option;
  ?rejected <doc text="The date and time (timestamp) when the vulnerability record was rejected (if applicable).">: string option;
  ?credits <doc text="Individuals or organizations credited with the discovery of the vulnerability.">: vulnerabilityCredits option;
  ?tools <doc text="The tool(s) used to identify, confirm, or score the vulnerability.">: vulnerabilityTools option;
  ?analysis <doc text="An assessment of the impact and exploitability of the vulnerability.">: vulnerabilityAnalysis option;
  ?affects <doc text="The components or services that are affected by the vulnerability.">: vulnerabilityAffects list option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type vulnerabilitySource <doc text="The source of vulnerability information. This is often the organization that published the vulnerability."> = {
  ?url <doc text="The url of the vulnerability documentation as provided by the source.">: string option;
  ?name <doc text="The name of the source.">: string option;
}

type rating <doc text="Defines the severity or risk ratings of a vulnerability."> = {
  ?source : vulnerabilitySource option;
  ?score <doc text="The numerical score of the rating.">: float option;
  ?severity : severity option;
  ?method_ <json name="method"> : scoreMethod option;
  ?vector <doc text="Textual representation of the metric values used to score the vulnerability">: string option;
  ?justification <doc text="A reason for rating the vulnerability as it was">: string option;
}

type impactAnalysisJustification <doc text="The rationale of why the impact analysis state was asserted."> = [
  | Code_not_present <json name="code_not_present">
  | Code_not_reachable <json name="code_not_reachable">
  | Requires_configuration <json name="requires_configuration">
  | Requires_dependency <json name="requires_dependency">
  | Requires_environment <json name="requires_environment">
  | Protected_by_compiler <json name="protected_by_compiler">
  | Protected_at_runtime <json name="protected_at_runtime">
  | Protected_at_perimeter <json name="protected_at_perimeter">
  | Protected_by_mitigating_control <json name="protected_by_mitigating_control">
] <ocaml repr="classic">

type impactAnalysisState <doc text="Declares the current state of an occurrence of a vulnerability, after automated or manual analysis."> = [
  | Resolved <json name="resolved">
  | Resolved_with_pedigree <json name="resolved_with_pedigree">
  | Exploitable <json name="exploitable">
  | In_triage <json name="in_triage">
  | False_positive <json name="false_positive">
  | Not_affected <json name="not_affected">
] <ocaml repr="classic">

type scoreMethod <doc text="Specifies the severity or risk scoring methodology or standard used."> = [
  | CVSSv2 <json name="CVSSv2">
  | CVSSv3 <json name="CVSSv3">
  | CVSSv31 <json name="CVSSv31">
  | CVSSv4 <json name="CVSSv4">
  | OWASP <json name="OWASP">
  | SSVC <json name="SSVC">
  | Other <json name="other">
] <ocaml repr="classic">

type severity <doc text="Textual representation of the severity of the vulnerability adopted by the analysis method. If the analysis method uses values other than what is provided, the user is expected to translate appropriately."> = [
  | Critical <json name="critical">
  | High <json name="high">
  | Medium <json name="medium">
  | Low <json name="low">
  | Info <json name="info">
  | None <json name="none">
  | Unknown <json name="unknown">
] <ocaml repr="classic">

type cwe <doc text="Integer representation of a Common Weaknesses Enumerations (CWE). For example 399 (of https://cwe.mitre.org/data/definitions/399.html)"> = int

type advisory <doc text="Title and location where advisory information can be obtained. An advisory is a notification of a threat to a component, service, or system."> = {
  ?title <doc text="A name of the advisory.">: string option;
  url <doc text="Location where the advisory can be obtained.">: string;
}

type releaseNotes = {
  type_ <json name="type"> : releaseType;
  ?title <doc text="The title of the release.">: string option;
  ?featuredImage <doc text="The URL to an image that may be prominently displayed with the release note.">: string option;
  ?socialImage <doc text="The URL to an image that may be used in messaging on social media platforms.">: string option;
  ?description <doc text="A short description of the release.">: string option;
  ?timestamp <doc text="The date and time (timestamp) when the release note was created.">: string option;
  ?aliases <doc text="One or more alternate names the release may be referred to. This may include unofficial terms used by development and marketing teams (e.g. code names).">: string list option;
  ?tags : tags option;
  ?resolves <doc text="A collection of issues that have been resolved.">: issue list option;
  ?notes <doc text="Zero or more release notes containing the locale and content. Multiple note objects may be specified to support release notes in a wide variety of languages.">: note list option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type note <doc text="A note containing the locale and content."> = {
  ?locale : localeType option;
  text : attachment;
}

type releaseType <doc text="The software versioning type. It is recommended that the release type use one of 'major', 'minor', 'patch', 'pre-release', or 'internal'. Representing all possible software release types is not practical, so standardizing on the recommended values, whenever possible, is strongly encouraged.\n\n* __major__ = A major release may contain significant changes or may introduce breaking changes.\n* __minor__ = A minor release, also known as an update, may contain a smaller number of changes than major releases.\n* __patch__ = Patch releases are typically unplanned and may resolve defects or important security issues.\n* __pre-release__ = A pre-release may include alpha, beta, or release candidates and typically have limited support. They provide the ability to preview a release prior to its general availability.\n* __internal__ = Internal releases are not for public consumption and are intended to be used exclusively by the project or manufacturer that produced it."> = string

type localeType <doc text="Defines a syntax for representing two character language code (ISO-639) followed by an optional two character country code. The language code must be lower case. If the country code is specified, the country code must be upper case. The language code and country code must be separated by a minus sign. Examples: en, en-US, fr, fr-CA"> = string

type property <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional."> = {
  name <doc text="The name of the property. Duplicate names are allowed, each potentially having a different value.">: string;
  ?value <doc text="The value of the property.">: string option;
}

type aggregateType = [
  | Complete <json name="complete">
  | Incomplete <json name="incomplete">
  | Incomplete_first_party_only <json name="incomplete_first_party_only">
  | Incomplete_first_party_proprietary_only <json name="incomplete_first_party_proprietary_only">
  | Incomplete_first_party_opensource_only <json name="incomplete_first_party_opensource_only">
  | Incomplete_third_party_only <json name="incomplete_third_party_only">
  | Incomplete_third_party_proprietary_only <json name="incomplete_third_party_proprietary_only">
  | Incomplete_third_party_opensource_only <json name="incomplete_third_party_opensource_only">
  | Unknown <json name="unknown">
  | Not_specified <json name="not_specified">
] <ocaml repr="classic">

type compositions = {
  ?bomref <json name="bom-ref"> : refType option;
  aggregate : aggregateType;
  ?assemblies <doc text="The bom-ref identifiers of the components or services being described. Assemblies refer to nested relationships whereby a constituent part may include other constituent parts. References do not cascade to child parts. References are explicit for the specified constituent part only.">: compositionsAssemblies list option;
  ?dependencies <doc text="The bom-ref identifiers of the components or services being described. Dependencies refer to a relationship whereby an independent constituent part requires another independent constituent part. References do not cascade to transitive dependencies. References are explicit for the specified dependency only.">: string list option;
  ?vulnerabilities <doc text="The bom-ref identifiers of the vulnerabilities being described.">: string list option;
  ?signature : signature option;
}

type componentEvidence <doc text="Provides the ability to document evidence collected through various forms of extraction or analysis."> = {
  ?identity <doc text="Evidence that substantiates the identity of a component. The identity may be an object or an array of identity objects. Support for specifying identity as a single object was introduced in CycloneDX v1.5. Arrays were introduced in v1.6. It is recommended that all implementations use arrays, even if only one identity object is specified.">: componentEvidenceIdentity option;
  ?occurrences <doc text="Evidence of individual instances of a component spread across multiple locations.">: componentEvidenceOccurrences list option;
  ?callstack <doc text="Evidence of the components use through the callstack.">: componentEvidenceCallstack option;
  ?licenses : licenseChoice option;
  ?copyright <doc text="Copyright evidence captures intellectual property assertions, providing evidence of possible ownership and legal protection.">: copyright list option;
}

type copyright <doc text="A copyright notice informing users of the underlying claims to copyright ownership in a published work."> = {
  text <doc text="The textual content of the copyright.">: string;
}

type dataFlowDirection <doc text="Specifies the flow direction of the data. Direction is relative to the service."> = [
  | Inbound <json name="inbound">
  | Outbound <json name="outbound">
  | Bidirectional <json name="bi-directional">
  | Unknown <json name="unknown">
] <ocaml repr="classic">

type serviceData = {
  flow : dataFlowDirection;
  classification : dataClassification;
  ?name <doc text="Name for the defined data">: string option;
  ?description <doc text="Short description of the data content and usage">: string option;
  ?governance : dataGovernance option;
  ?source <doc text="The URI, URL, or BOM-Link of the components or services the data came in from">: serviceDataSource list option;
  ?destination <doc text="The URI, URL, or BOM-Link of the components or services the data is sent to">: serviceDataDestination list option;
}

type service = {
  ?bomref <json name="bom-ref"> : refType option;
  ?provider : organizationalEntity option;
  ?group <doc text="The grouping name, namespace, or identifier. This will often be a shortened, single name of the company or project that produced the service or domain name. Whitespace and special characters should be avoided.">: string option;
  name <doc text="The name of the service. This will often be a shortened, single name of the service.">: string;
  ?version : version option;
  ?description <doc text="Specifies a description for the service">: string option;
  ?endpoints <doc text="The endpoint URIs of the service. Multiple endpoints are allowed.">: string list option;
  ?authenticated <doc text="A boolean value indicating if the service requires authentication. A value of true indicates the service requires authentication prior to use. A value of false indicates the service does not require authentication.">: bool option;
  ?xtrustboundary <json name="x-trust-boundary"> <doc text="A boolean value indicating if use of the service crosses a trust zone or boundary. A value of true indicates that by using the service, a trust boundary is crossed. A value of false indicates that by using the service, a trust boundary is not crossed.">: bool option;
  ?trustZone <doc text="The name of the trust zone the service resides in.">: string option;
  ?data <doc text="Specifies information about the data including the directional flow of data and the data classification.">: serviceData list option;
  ?licenses : licenseChoice option;
  ?patentAssertions : patentAssertions option;
  ?externalReferences <doc text="External references provide a way to document systems, sites, and information that may be relevant but are not included with the BOM. They may also establish specific relationships within or external to the BOM.">: externalReference list option;
  ?services <doc text="A list of services included or deployed behind the parent service. This is not a dependency tree. It provides a way to specify a hierarchical representation of service assemblies.">: service list option;
  ?releaseNotes : releaseNotes option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
  ?tags : tags option;
  ?signature : signature option;
}

type dependency <doc text="Defines the direct dependencies of a component, service, or the components provided/implemented by a given component. Components or services that do not have their own dependencies must be declared as empty elements within the graph. Components or services that are not represented in the dependency graph may have unknown dependencies. It is recommended that implementations assume this to be opaque and not an indicator of an object being dependency-free. It is recommended to leverage compositions to indicate unknown dependency graphs."> = {
  ref : refLinkType;
  ?dependsOn <doc text="The bom-ref identifiers of the components or services that are dependencies of this dependency object.">: refLinkType list option;
  ?provides <doc text="The bom-ref identifiers of the components or services that define a given specification or standard, which are provided or implemented by this dependency object.\nFor example, a cryptographic library which implements a cryptographic algorithm. A component which implements another component does not imply that the implementation is in use.">: refLinkType list option;
}

type externalReference <doc text="External references provide a way to document systems, sites, and information that may be relevant but are not included with the BOM. They may also establish specific relationships within or external to the BOM."> = {
  url <doc text="The URI (URL or URN) to the external reference. External references are URIs and therefore can accept any URL scheme including https ([RFC-7230](https://www.ietf.org/rfc/rfc7230.txt)), mailto ([RFC-2368](https://www.ietf.org/rfc/rfc2368.txt)), tel ([RFC-3966](https://www.ietf.org/rfc/rfc3966.txt)), and dns ([RFC-4501](https://www.ietf.org/rfc/rfc4501.txt)). External references may also include formally registered URNs such as [CycloneDX BOM-Link](https://cyclonedx.org/capabilities/bomlink/) to reference CycloneDX BOMs or any object within a BOM. BOM-Link transforms applicable external references into relationships that can be expressed in a BOM or across BOMs.">: externalReferenceUrl;
  ?comment <doc text="A comment describing the external reference">: string option;
  type_ <json name="type"> <doc text="Specifies the type of external reference.">: externalReferenceType;
  ?hashes <doc text="The hashes of the external reference (if applicable).">: hash list option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
}

type identifiableAction <doc text="Specifies an individual commit"> = {
  ?timestamp <doc text="The timestamp in which the action occurred">: string option;
  ?name <doc text="The name of the individual who performed the action">: string option;
  ?email <doc text="The email address of the individual who performed the action">: string option;
}

type issue <doc text="An individual issue that has been resolved."> = {
  type_ <json name="type"> <doc text="Specifies the type of issue">: issueType;
  ?id <doc text="The identifier of the issue assigned by the source of the issue">: string option;
  ?name <doc text="The name of the issue">: string option;
  ?description <doc text="A description of the issue">: string option;
  ?source <doc text="The source of the issue where it is documented">: issueSource option;
  ?references <doc text="A collection of URL's for reference. Multiple URLs are allowed.">: string list option;
}

type diff <doc text="The patch file (or diff) that shows changes. Refer to https://en.wikipedia.org/wiki/Diff"> = {
  ?text : attachment option;
  ?url <doc text="Specifies the URL to the diff">: string option;
}

type patch <doc text="Specifies an individual patch"> = {
  type_ <json name="type"> <doc text="Specifies the purpose for the patch including the resolution of defects, security issues, or new behavior or functionality.">: patchType;
  ?diff : diff option;
  ?resolves <doc text="A collection of issues the patch resolves">: issue list option;
}

type commit <doc text="Specifies an individual commit"> = {
  ?uid <doc text="A unique identifier of the commit. This may be version control specific. For example, Subversion uses revision numbers whereas git uses commit hashes.">: string option;
  ?url <doc text="The URL to the commit. This URL will typically point to a commit in a version control system.">: string option;
  ?author : identifiableAction option;
  ?committer : identifiableAction option;
  ?message <doc text="The text description of the contents of the commit">: string option;
}

type licenseChoice <doc text="A list of SPDX licenses and/or named licenses and/or SPDX License Expression."> = licenseChoiceItems list

type licenseAcknowledgementEnumeration <doc text="Declared licenses and concluded licenses represent two different stages in the licensing process within software development. Declared licenses refer to the initial intention of the software authors regarding the licensing terms under which their code is released. On the other hand, concluded licenses are the result of a comprehensive analysis of the project's codebase to identify and confirm the actual licenses of the components used, which may differ from the initially declared licenses. While declared licenses provide an upfront indication of the licensing intentions, concluded licenses offer a more thorough understanding of the actual licensing within a project, facilitating proper compliance and risk management. Observed licenses are defined in `@.evidence.licenses`. Observed licenses form the evidence necessary to substantiate a concluded license."> = [
  | Declared <json name="declared">
  | Concluded <json name="concluded">
] <ocaml repr="classic">

type license <doc text="Specifies the details and attributes related to a software license. It can either include a valid SPDX license identifier or a named license, along with additional properties such as license acknowledgment, comprehensive commercial licensing information, and the full text of the license."> = [
  | Jsonlicense_1 of json (* license/Jsonlicense_1 *)
  | Jsonlicense_2 of json (* license/Jsonlicense_2 *)
] <json adapter.ocaml="Jsonschema2atd_runtime.Adapter.One_of"> <ocaml repr="classic">

type licensing <doc text="Licensing details describing the licensor/licensee, license type, renewal and expiration dates, and other important metadata"> = {
  ?altIds <doc text="License identifiers that may be used to manage licenses and their lifecycle">: string list option;
  ?licensor <doc text="The individual or organization that grants a license to another individual or organization">: licensingLicensor option;
  ?licensee <doc text="The individual or organization for which a license was granted to">: licensingLicensee option;
  ?purchaser <doc text="The individual or organization that purchased the license">: licensingPurchaser option;
  ?purchaseOrder <doc text="The purchase order identifier the purchaser sent to a supplier or vendor to authorize a purchase">: string option;
  ?licenseTypes <doc text="The type of license(s) that was granted to the licensee.">: licensingLicenseTypes list option;
  ?lastRenewal <doc text="The timestamp indicating when the license was last renewed. For new purchases, this is often the purchase or acquisition date. For non-perpetual licenses or subscriptions, this is the timestamp of when the license was last renewed.">: string option;
  ?expiration <doc text="The timestamp indicating when the current license expires (if applicable).">: string option;
}

type hashcontent <doc text="The value of the hash."> = string

type hashalg <doc text="The algorithm that generated the hash value."> = [
  | MD5 <json name="MD5">
  | SHA1 <json name="SHA-1">
  | SHA256 <json name="SHA-256">
  | SHA384 <json name="SHA-384">
  | SHA512 <json name="SHA-512">
  | SHA3256 <json name="SHA3-256">
  | SHA3384 <json name="SHA3-384">
  | SHA3512 <json name="SHA3-512">
  | BLAKE2b256 <json name="BLAKE2b-256">
  | BLAKE2b384 <json name="BLAKE2b-384">
  | BLAKE2b512 <json name="BLAKE2b-512">
  | BLAKE3 <json name="BLAKE3">
  | Streebog256 <json name="Streebog-256">
  | Streebog512 <json name="Streebog-512">
] <ocaml repr="classic">

type hash = {
  alg : hashalg;
  content : hashcontent;
}

type attachment <doc text="Specifies the metadata and content for an attachment."> = {
  ~contentType <doc text="Specifies the format and nature of the data being attached, helping systems correctly interpret and process the content. Common content type examples include `application/json` for JSON data and `text/plain` for plain text documents.\n [RFC 2045 section 5.1](https://www.ietf.org/rfc/rfc2045.html#section-5.1) outlines the structure and use of content types. For a comprehensive list of registered content types, refer to the [IANA media types registry](https://www.iana.org/assignments/media-types/media-types.xhtml)."> <ocaml default="\"text/plain\"">: string;
  ?encoding <doc text="Specifies the encoding the text is represented in.">: attachmentEncoding option;
  content <doc text="The attachment data. Proactive controls such as input validation and sanitization should be employed to prevent misuse of attachment text.">: string;
}

type swid <doc text="Specifies metadata and content for ISO-IEC 19770-2 Software Identification (SWID) Tags."> = {
  tagId <doc text="Maps to the tagId of a SoftwareIdentity.">: string;
  name <doc text="Maps to the name of a SoftwareIdentity.">: string;
  ~version <doc text="Maps to the version of a SoftwareIdentity."> <ocaml default="\"0.0\"">: string;
  ~tagVersion <doc text="Maps to the tagVersion of a SoftwareIdentity."> <ocaml default="0">: int;
  ~patch <doc text="Maps to the patch of a SoftwareIdentity."> <ocaml default="false">: bool;
  ?text : attachment option;
  ?url <doc text="The URL to the SWID file.">: string option;
}

type component = {
  type_ <json name="type"> <doc text="Specifies the type of component. For software components, classify as application if no more specific appropriate classification is available or cannot be determined for the component.">: componentType;
  ?mimetype <json name="mime-type"> <doc text="The mime-type of the component. When used on file components, the mime-type can provide additional context about the kind of file being represented, such as an image, font, or executable. Some library or framework components may also have an associated mime-type.">: string option;
  ?bomref <json name="bom-ref"> : refType option;
  ?supplier : organizationalEntity option;
  ?manufacturer : organizationalEntity option;
  ?authors <doc text="The person(s) who created the component.\nAuthors are common in components created through manual processes. Components created through automated means may have `@.manufacturer` instead.">: organizationalContact list option;
  ?author <doc text="[Deprecated] This will be removed in a future version. Use `@.authors` or `@.manufacturer` instead.\nThe person(s) or organization(s) that authored the component">: string option;
  ?publisher <doc text="The person(s) or organization(s) that published the component">: string option;
  ?group <doc text="The grouping name or identifier. This will often be a shortened, single name of the company or project that produced the component, or the source package or domain name. Whitespace and special characters should be avoided. Examples include: apache, org.apache.commons, and apache.org.">: string option;
  name <doc text="The name of the component. This will often be a shortened, single name of the component. Examples: commons-lang3 and jquery">: string;
  ?version : version option;
  ?versionRange : versionRange option;
  ~isExternal <doc text="Determine whether this component is external.\nAn external component is one that is not part of an assembly, but is expected to be provided by the environment, regardless of the component's `.scope`. This setting can be useful for distinguishing which components are bundled with the product and which can be relied upon to be present in the deployment environment.\nThis may be set to `true` for runtime components only. For `$.metadata.component`, it must be set to `false`."> <ocaml default="false">: bool;
  ?description <doc text="Specifies a description for the component">: string option;
  ~scope <doc text="Specifies the scope of the component. If scope is not specified, 'required' scope SHOULD be assumed by the consumer of the BOM."> <ocaml default="Required">: componentScope;
  ?hashes <doc text="The hashes of the component.">: hash list option;
  ?licenses : licenseChoice option;
  ?copyright <doc text="A copyright notice informing users of the underlying claims to copyright ownership in a published work.">: string option;
  ?patentAssertions : patentAssertions option;
  ?cpe <doc text="Asserts the identity of the component using CPE. The CPE must conform to the CPE 2.2 or 2.3 specification. See [https://nvd.nist.gov/products/cpe](https://nvd.nist.gov/products/cpe). Refer to `@.evidence.identity` to optionally provide evidence that substantiates the assertion of the component's identity.">: string option;
  ?purl <doc text="Asserts the identity of the component using package-url (purl). The purl, if specified, must be valid and conform to the specification defined at: [https://github.com/package-url/purl-spec](https://github.com/package-url/purl-spec). Refer to `@.evidence.identity` to optionally provide evidence that substantiates the assertion of the component's identity.">: string option;
  ?omniborId <doc text="Asserts the identity of the component using the OmniBOR Artifact ID. The OmniBOR, if specified, must be valid and conform to the specification defined at: [https://www.iana.org/assignments/uri-schemes/prov/gitoid](https://www.iana.org/assignments/uri-schemes/prov/gitoid). Refer to `@.evidence.identity` to optionally provide evidence that substantiates the assertion of the component's identity.">: string list option;
  ?swhid <doc text="Asserts the identity of the component using the Software Heritage persistent identifier (SWHID). The SWHID, if specified, must be valid and conform to the specification defined at: [https://docs.softwareheritage.org/devel/swh-model/persistent-identifiers.html](https://docs.softwareheritage.org/devel/swh-model/persistent-identifiers.html). Refer to `@.evidence.identity` to optionally provide evidence that substantiates the assertion of the component's identity.">: string list option;
  ?swid : swid option;
  ?modified <doc text="[Deprecated] This will be removed in a future version. Use the pedigree element instead to supply information on exactly how the component was modified.\nA boolean value indicating if the component has been modified from the original. A value of true indicates the component is a derivative of the original. A value of false indicates the component has not been modified from the original.">: bool option;
  ?pedigree <doc text="Component pedigree is a way to document complex supply chain scenarios where components are created, distributed, modified, redistributed, combined with other components, etc. Pedigree supports viewing this complex chain from the beginning, the end, or anywhere in the middle. It also provides a way to document variants where the exact relation may not be known.">: componentPedigree option;
  ?externalReferences <doc text="External references provide a way to document systems, sites, and information that may be relevant but are not included with the BOM. They may also establish specific relationships within or external to the BOM.">: externalReference list option;
  ?components <doc text="A list of software and hardware components included in the parent component. This is not a dependency tree. It provides a way to specify a hierarchical representation of component assemblies, similar to system &#8594; subsystem &#8594; parts assembly in physical supply chains.">: component list option;
  ?evidence : componentEvidence option;
  ?releaseNotes : releaseNotes option;
  ?modelCard : modelCard option;
  ?data <doc text="This object SHOULD be specified for any component of type `data` and must not be specified for other component types.">: componentData list option;
  ?cryptoProperties : cryptoProperties option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
  ?tags : tags option;
  ?signature : signature option;
}

type organizationalContact = {
  ?bomref <json name="bom-ref"> : refType option;
  ?name <doc text="The name of a contact">: string option;
  ?email <doc text="The email address of the contact.">: string option;
  ?phone <doc text="The phone number of the contact.">: string option;
}

type organizationalEntity = {
  ?bomref <json name="bom-ref"> : refType option;
  ?name <doc text="The name of the organization">: string option;
  ?address : postalAddress option;
  ?url <doc text="The URL of the organization. Multiple URLs are allowed.">: string list option;
  ?contact <doc text="A contact at the organization. Multiple contacts are allowed.">: organizationalContact list option;
}

type tool <doc text="[Deprecated] This will be removed in a future version. Use component or service instead.\nInformation about the automated or manual tool used"> = {
  ?vendor <doc text="The name of the vendor who created the tool">: string option;
  ?name <doc text="The name of the tool">: string option;
  ?version : version option;
  ?hashes <doc text="The hashes of the tool (if applicable).">: hash list option;
  ?externalReferences <doc text="External references provide a way to document systems, sites, and information that may be relevant, but are not included with the BOM. They may also establish specific relationships within or external to the BOM.">: externalReference list option;
}

type tlpClassification <doc text="Traffic Light Protocol (TLP) is a classification system for identifying the potential risk associated with artefact, including whether it is subject to certain types of legal, financial, or technical threats. Refer to [https://www.first.org/tlp/](https://www.first.org/tlp/) for further information.\nThe default classification is \"CLEAR\""> = [
  | CLEAR <json name="CLEAR">
  | GREEN <json name="GREEN">
  | AMBER <json name="AMBER">
  | AMBER_AND_STRICT <json name="AMBER_AND_STRICT">
  | RED <json name="RED">
] <ocaml repr="classic">

type metadata = {
  ?timestamp <doc text="The date and time (timestamp) when the BOM was created.">: string option;
  ?lifecycles <doc text="Lifecycles communicate the stage(s) in which data in the BOM was captured. Different types of data may be available at various phases of a lifecycle, such as the Software Development Lifecycle (SDLC), IT Asset Management (ITAM), and Software Asset Management (SAM). Thus, a BOM may include data specific to or only obtainable in a given lifecycle.">: metadataLifecycles list option;
  ?tools <doc text="The tool(s) used in the creation, enrichment, and validation of the BOM.">: metadataTools option;
  ?manufacturer : organizationalEntity option;
  ?authors <doc text="The person(s) who created the BOM.\nAuthors are common in BOMs created through manual processes. BOMs created through automated means may have `@.manufacturer` instead.">: organizationalContact list option;
  ?component : component option;
  ?manufacture : organizationalEntity option;
  ?supplier : organizationalEntity option;
  ?licenses : licenseChoice option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
  ?distributionConstraints <doc text="Conditions and constraints governing the sharing and distribution of the data or components described by this BOM.">: metadataDistributionConstraints option;
}

type bomLink = [
  | BomLinkDocumentType of bomLinkDocumentType
  | BomLinkElementType of bomLinkElementType
] <json adapter.ocaml="Jsonschema2atd_runtime.Adapter.One_of"> <ocaml repr="classic">

type bomLinkElementType <doc text="Descriptor for an element in a BOM document. See https://cyclonedx.org/capabilities/bomlink/"> = string

type bomLinkDocumentType <doc text="Descriptor for another BOM document. See https://cyclonedx.org/capabilities/bomlink/"> = string

type refLinkType <doc text="Descriptor for an element identified by the attribute 'bom-ref' in the same BOM document.\nIn contrast to `bomLinkElementType`."> = json (* refLinkType *)

type refType <doc text="Identifier for referable and therefore interlinkable elements.\nValue SHOULD not start with the BOM-Link intro 'urn:cdx:' to avoid conflicts with BOM-Links."> = string

type cycloneDXBillofMaterialsStandard = {
  ?schema <json name="$schema"> : string option;
  bomFormat <doc text="Specifies the format of the BOM. This helps to identify the file as CycloneDX since BOMs do not have a filename convention, nor does JSON schema support namespaces. This value must be \"CycloneDX\".">: cycloneDXBillofMaterialsStandardBomFormat;
  specVersion <doc text="The version of the CycloneDX specification the BOM conforms to.">: string;
  ?serialNumber <doc text="Every BOM generated SHOULD have a unique serial number, even if the contents of the BOM have not changed over time. If specified, the serial number must conform to [RFC 4122](https://www.ietf.org/rfc/rfc4122.html). Use of serial numbers is recommended.">: string option;
  ~version <doc text="Whenever an existing BOM is modified, either manually or through automated processes, the version of the BOM SHOULD be incremented by 1. When a system is presented with multiple BOMs with identical serial numbers, the system SHOULD use the most recent version of the BOM. The default version is '1'."> <ocaml default="1">: int;
  ?metadata : metadata option;
  ?components <doc text="A list of software and hardware components.">: component list option;
  ?services <doc text="A list of services. This may include microservices, function-as-a-service, and other types of network or intra-process services.">: service list option;
  ?externalReferences <doc text="External references provide a way to document systems, sites, and information that may be relevant but are not included with the BOM. They may also establish specific relationships within or external to the BOM.">: externalReference list option;
  ?dependencies <doc text="Provides the ability to document dependency relationships including provided & implemented components.">: dependency list option;
  ?compositions <doc text="Compositions describe constituent parts (including components, services, and dependency relationships) and their completeness. The completeness of vulnerabilities expressed in a BOM may also be described.">: compositions list option;
  ?vulnerabilities <doc text="Vulnerabilities identified in components or services.">: vulnerability list option;
  ?annotations <doc text="Comments made by people, organizations, or tools about any object with a bom-ref, such as components, services, vulnerabilities, or the BOM itself. Unlike inventory information, annotations may contain opinions or commentary from various stakeholders. Annotations may be inline (with inventory) or externalized via BOM-Link and may optionally be signed.">: annotations list option;
  ?formulation <doc text="Describes the formulation of any referencable object within the BOM, including components, services, metadata, declarations, or the BOM itself. This may encompass how the object was created, assembled, deployed, tested, certified, or otherwise brought into its present form. Common examples include software build pipelines, deployment processes, AI/ML model training, cryptographic key generation or certification, and third-party audits. Processes are modeled using declared and observed formulas, composed of workflows, tasks, and individual steps.">: formula list option;
  ?declarations <doc text="The list of declarations which describe the conformance to standards. Each declaration may include attestations, claims, and evidence.">: cycloneDXBillofMaterialsStandardDeclarations option;
  ?definitions <doc text="A collection of reusable objects that are defined and may be used elsewhere in the BOM.">: cycloneDXBillofMaterialsStandardDefinitions option;
  ?citations <doc text="A collection of attributions indicating which entity supplied information for specific fields within the BOM.">: citation list option;
  ?properties <doc text="Provides the ability to document properties in a name-value store. This provides flexibility to include data not officially supported in the standard without having to use additional namespaces or create extensions. Unlike key-value stores, properties support duplicate names, each potentially having different values. Property names of interest to the general public are encouraged to be registered in the [CycloneDX Property Taxonomy](https://github.com/CycloneDX/cyclonedx-property-taxonomy). Formal registration is optional.">: property list option;
  ?signature : signature option;
}
